{
  "name": "flowbot",
  "version": "0.1.0",
  "private": true,
  "description": "FlowBot — multi-tenant chat automation SaaS. Next.js + serverless on Vercel + Upstash Redis + Postgres.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^14.2.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^3.2.29",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vercel": "^37.0.0"
  }
}
