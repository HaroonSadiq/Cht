# ─── Database (Supabase / Neon / any Postgres) ─────────────
DATABASE_URL="postgresql://user:pass@host:5432/flowbot?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/flowbot?sslmode=require"

# ─── Upstash Redis (queue + cache) ─────────────────────────
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"

# ─── Auth / Encryption ─────────────────────────────────────
# 32-byte base64 key — generate: openssl rand -base64 32
ENCRYPTION_KEY=""
# 32-byte base64 key for JWT signing
JWT_SECRET=""

# ─── Meta (Facebook + Instagram + Messenger) ───────────────
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN="any-random-string-you-pick"
# Webhook signature verification
META_WEBHOOK_SECRET=""
# OAuth redirect URI — set this in your Meta app dashboard
META_REDIRECT_URI="https://your-domain.com/api/oauth/meta/callback"

# ─── TikTok ────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="https://your-domain.com/api/oauth/tiktok/callback"

# ─── Cron security (so random callers can't drain the queue) ─
CRON_SECRET=""

# ─── App ───────────────────────────────────────────────────
APP_URL="https://your-domain.com"
NODE_ENV="development"
